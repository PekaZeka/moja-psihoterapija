---
import PageLayout from "./PageLayout.astro";
import Breadcrumbs from "@/components/common/Breadcrumbs.astro";
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";
import { SITE } from "@/lib/constants";
import { articleSchema, breadcrumbSchema } from "@/lib/schema";

interface Props {
  title: string;
  description: string;
  lang: Lang;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  slug: string;
}

const { title, description, lang, pubDate, updatedDate, heroImage, slug } = Astro.props;
const t = useTranslations(lang);

const dateStr = pubDate.toLocaleDateString(lang === "sr" ? "sr-Latn-RS" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const pageUrl = `${SITE.url}/${lang}/blog/${slug}/`;
const schemas = [
  articleSchema(title, description, pageUrl, pubDate.toISOString(), updatedDate?.toISOString(), heroImage),
  breadcrumbSchema([
    { name: t("nav.home"), url: `${SITE.url}/${lang}/` },
    { name: t("nav.blog"), url: `${SITE.url}/${lang}/blog/` },
    { name: title, url: pageUrl },
  ]),
];
---

<PageLayout
  title={title}
  description={description}
  lang={lang}
  ogType="article"
  ogImage={heroImage}
  schema={schemas}
  alternateUrls={{ sr: `/sr/blog/${slug}/`, en: `/en/blog/${slug}/` }}
>
  <article class="py-12 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="mb-8">
        <Breadcrumbs
          lang={lang}
          items={[
            { label: t("nav.blog"), href: `/${lang}/blog/` },
            { label: title },
          ]}
        />
      </div>

      <header class="mb-10">
        <h1 class="text-h1 lg:text-display font-heading text-primary-900 mb-4">
          {title}
        </h1>
        <div class="flex items-center gap-4 text-text-muted text-sm">
          <time datetime={pubDate.toISOString()}>
            {t("blog.publishedOn")}: {dateStr}
          </time>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            {SITE.therapist.name}
          </span>
        </div>
      </header>

      {heroImage && (
        <div class="mb-10 rounded-2xl overflow-hidden">
          <img src={heroImage} alt={title} class="w-full h-64 lg:h-96 object-cover" />
        </div>
      )}

      <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-primary-900 prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline">
        <slot />
      </div>

      <!-- Author card -->
      <div class="mt-12 p-6 bg-surface-300 rounded-2xl flex flex-col sm:flex-row items-center gap-4">
        <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center shrink-0">
          <span class="text-primary-600 text-2xl font-heading">MJ</span>
        </div>
        <div class="text-center sm:text-left">
          <p class="font-heading text-lg text-primary-900">{SITE.therapist.name}</p>
          <p class="text-text-muted text-sm">{lang === "sr" ? SITE.therapist.title : SITE.therapist.titleEn}</p>
        </div>
      </div>
    </div>
  </article>
</PageLayout>
