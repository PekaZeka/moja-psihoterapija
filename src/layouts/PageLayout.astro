---
import BaseLayout from "./BaseLayout.astro";
import Header from "@/components/common/Header.astro";
import Footer from "@/components/common/Footer.astro";
import FloatingCallButton from "@/components/common/FloatingCallButton.astro";
import type { Lang } from "@/i18n/utils";

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  alternateUrls?: { sr: string; en: string };
  noindex?: boolean;
  schema?: object | object[];
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Header lang={props.lang} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer lang={props.lang} />
  <FloatingCallButton />
</BaseLayout>
