---
import PageLayout from "@/layouts/PageLayout.astro";
import Breadcrumbs from "@/components/common/Breadcrumbs.astro";
import { SITE } from "@/lib/constants";
import { useTranslations } from "@/i18n/utils";

const lang = "sr";
const t = useTranslations(lang);
---

<PageLayout
  title="Kontakt"
  description="Kontaktirajte nas za besplatne konsultacije. Telefon, WhatsApp, Viber ili email. Psihoterapija u Beogradu i online."
  lang={lang}
  alternateUrls={{ sr: "/sr/kontakt/", en: "/en/contact/" }}
>
  <section class="py-12 lg:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <Breadcrumbs lang={lang} items={[{ label: "Kontakt" }]} />
      </div>

      <h1 class="font-heading text-h1 lg:text-display text-primary-900 mb-3">
        {t("contact.title")}
      </h1>
      <p class="text-lg text-text-secondary mb-12">{t("contact.subtitle")}</p>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <form id="contact-form" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-medium text-text-primary mb-1.5">{t("contact.name")} *</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border border-surface-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors bg-white" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-text-primary mb-1.5">{t("contact.phone")} *</label>
              <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 rounded-xl border border-surface-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors bg-white" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-text-primary mb-1.5">{t("contact.email")}</label>
              <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-xl border border-surface-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors bg-white" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">{t("contact.method")}</label>
              <div class="flex flex-wrap gap-3">
                {["methodPhone", "methodWhatsApp", "methodViber", "methodEmail"].map((key) => (
                  <label class="flex items-center gap-2 px-4 py-2 rounded-lg border border-surface-400 cursor-pointer hover:border-primary-300 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition-colors">
                    <input type="radio" name="contactMethod" value={key} class="text-primary-600" />
                    <span class="text-sm">{t(`contact.${key}`)}</span>
                  </label>
                ))}
              </div>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-text-primary mb-1.5">{t("contact.message")}</label>
              <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-xl border border-surface-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors bg-white resize-none"></textarea>
            </div>
            <!-- Honeypot -->
            <div class="hidden" aria-hidden="true">
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </div>
            <button type="submit" id="submit-btn" class="w-full sm:w-auto px-8 py-3.5 bg-primary-600 text-white font-medium rounded-xl shadow-lg hover:bg-primary-700 transition-all text-lg">
              {t("contact.send")}
            </button>
            <div id="form-status" class="hidden p-4 rounded-xl text-sm"></div>
          </form>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-2 space-y-6">
          <div class="p-6 bg-surface-300 rounded-2xl space-y-5">
            <h2 class="font-heading text-h4 text-primary-900">
              {lang === "sr" ? "Direktan kontakt" : "Direct contact"}
            </h2>
            <a href={`tel:${SITE.phoneRaw}`} data-event="phone_click" class="flex items-center gap-3 text-text-secondary hover:text-primary-600 transition-colors">
              <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <span>{SITE.phone}</span>
            </a>
            <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" data-event="whatsapp_click" class="flex items-center gap-3 text-text-secondary hover:text-green-600 transition-colors">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <span>WhatsApp</span>
            </a>
            <a href={SITE.viber} target="_blank" rel="noopener noreferrer" data-event="viber_click" class="flex items-center gap-3 text-text-secondary hover:text-violet-600 transition-colors">
              <div class="w-10 h-10 bg-violet-100 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-violet-600" fill="currentColor" viewBox="0 0 24 24"><path d="M11.997 0C5.372 0 .013 5.362.013 11.988c0 2.47.74 4.76 2.013 6.676L.523 23.262a.5.5 0 00.638.638l4.598-1.503a11.957 11.957 0 006.238 1.616c6.625 0 11.984-5.362 11.984-11.988C24 5.362 18.622 0 11.997 0zm5.93 16.52c-.237.663-.686 1.222-1.291 1.571-.607.35-1.298.497-1.982.428-2.208-.328-4.25-1.438-5.745-3.136-1.496-1.696-2.293-3.89-2.227-6.133a4.05 4.05 0 01.424-1.734 3.108 3.108 0 011.135-1.218c.405-.24.877-.336 1.34-.271.155.022.297.099.401.215.443.486 1.032 1.547 1.28 2.185.117.3.059.64-.152.887-.078.09-.172.166-.276.222-.104.057-.217.096-.334.116l-.01.002c-.133.026-.257.08-.365.16-.108.082-.197.186-.259.306-.062.12-.095.254-.095.389v.002c.012.53.32 1.408 1.09 2.26.773.852 1.546 1.145 2.064 1.158.134 0 .268-.03.389-.09.12-.06.225-.148.308-.255.082-.106.14-.229.168-.36l.003-.011c.021-.117.06-.23.118-.334.057-.104.135-.197.228-.274.25-.21.591-.265.893-.144.638.252 1.693.852 2.172 1.308.113.105.188.248.208.403.059.46-.073.933-.31 1.596z"/></svg>
              </div>
              <span>Viber</span>
            </a>
            <a href={`mailto:${SITE.email}`} data-event="email_click" class="flex items-center gap-3 text-text-secondary hover:text-primary-600 transition-colors">
              <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <span>{SITE.email}</span>
            </a>
          </div>

          <div class="p-6 bg-primary-50 rounded-2xl">
            <h3 class="font-heading text-h4 text-primary-900 mb-2">Lokacija</h3>
            <p class="text-text-secondary">Beograd, Vračar</p>
            <p class="text-sm text-text-muted mt-2">Moguća je i online terapija sa klijentima iz celog sveta.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script is:inline>
  document.getElementById('contact-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('submit-btn');
    var status = document.getElementById('form-status');
    var form = e.target;

    // Honeypot check
    if (form.website.value) return;

    btn.disabled = true;
    btn.textContent = 'Šaljem...';

    try {
      var res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: form.name.value,
          phone: form.phone.value,
          email: form.email.value,
          contactMethod: form.contactMethod ? form.contactMethod.value : '',
          message: form.message.value,
        }),
      });

      if (res.ok) {
        status.className = 'p-4 rounded-xl text-sm bg-green-50 text-green-800 border border-green-200';
        status.textContent = 'Poruka je uspešno poslata! Javićemo vam se uskoro.';
        form.reset();
        if (window.dataLayer) window.dataLayer.push({ event: 'form_submit' });
      } else {
        throw new Error();
      }
    } catch (err) {
      status.className = 'p-4 rounded-xl text-sm bg-red-50 text-red-800 border border-red-200';
      status.textContent = 'Došlo je do greške. Molimo pokušajte ponovo ili nas pozovite direktno.';
    }

    status.classList.remove('hidden');
    btn.disabled = false;
    btn.textContent = 'Pošaljite poruku';
  });
</script>
