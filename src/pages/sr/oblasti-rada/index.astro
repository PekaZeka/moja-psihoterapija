---
import { Image } from "astro:assets";
import PageLayout from "@/layouts/PageLayout.astro";
import Breadcrumbs from "@/components/common/Breadcrumbs.astro";
import { getCollection } from "astro:content";

const lang = "sr";
const areas = (await getCollection("areas", ({ data }) => data.lang === "sr"))
  .sort((a, b) => a.data.order - b.data.order);
---

<PageLayout
  title="Oblasti rada"
  description="Oblasti psihoterapijskog rada: anksioznost, depresija, samopouzdanje, partnerski odnosi, roditeljstvo i mnoge druge teme."
  lang={lang}
  alternateUrls={{ sr: "/sr/oblasti-rada/", en: "/en/areas-of-work/" }}
>
  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <Breadcrumbs lang={lang} items={[{ label: "Oblasti rada" }]} />
      </div>

      <h1 class="font-heading text-h1 lg:text-display text-primary-900 mb-6">
        Oblasti rada
      </h1>
      <p class="text-lg text-text-secondary max-w-3xl mb-12">
        Radimo na širokom spektru tema. Izaberite oblast koja vas zanima i saznajte više o našem pristupu.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {areas.map((area) => (
          <a
            href={`/sr/oblasti-rada/${area.slug.replace("sr/", "")}/`}
            class="group block rounded-2xl border border-surface-400/30 bg-white hover:shadow-xl hover:border-primary-300 transition-all duration-300 overflow-hidden"
          >
            {area.data.illustration ? (
              <div class="flex justify-center items-center bg-surface-50 p-3 min-h-[13rem]">
                <Image
                  src={area.data.illustration}
                  alt=""
                  class="max-h-48 w-auto object-contain group-hover:scale-105 transition-transform duration-500"
                  width={300}
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="h-44 bg-gradient-to-br from-primary-100 to-accent-100 flex items-center justify-center">
                <svg class="w-12 h-12 text-primary-400/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
              </div>
            )}
            <div class="p-6">
              <h2 class="font-heading text-h4 text-primary-900 group-hover:text-primary-600 transition-colors mb-2">
                {area.data.shortTitle}
              </h2>
              <p class="text-sm text-text-muted line-clamp-2">{area.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
