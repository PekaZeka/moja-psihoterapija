---
import { Image } from "astro:assets";
import PageLayout from "@/layouts/PageLayout.astro";
import Breadcrumbs from "@/components/common/Breadcrumbs.astro";
import { getCollection, render } from "astro:content";
import { SITE } from "@/lib/constants";
import { serviceSchema, breadcrumbSchema } from "@/lib/schema";
import { areaSlugMap } from "@/i18n/utils";

export const prerender = true;

export async function getStaticPaths() {
  const areas = await getCollection("areas", ({ data }) => data.lang === "en");
  return areas.map((area) => {
    const slug = area.id.replace("en/", "").replace(".md", "");
    return { params: { slug }, props: { area } };
  });
}

const { area } = Astro.props;
const { Content } = await render(area);
const slug = Astro.params.slug!;
const lang = "en";

const allAreas = (await getCollection("areas", ({ data }) => data.lang === "en"))
  .sort((a, b) => a.data.order - b.data.order);

const relatedAreas = area.data.relatedAreas
  ? allAreas.filter((a) => {
      const aSlug = a.id.replace("en/", "").replace(".md", "");
      return area.data.relatedAreas!.includes(aSlug);
    })
  : [];

const srSlug = areaSlugMap[slug] || slug;
const schemas = [
  serviceSchema(area.data.title, area.data.description, slug, "en"),
  breadcrumbSchema([
    { name: "Home", url: `${SITE.url}/en/` },
    { name: "Areas of Work", url: `${SITE.url}/en/areas-of-work/` },
    { name: area.data.title, url: `${SITE.url}/en/areas-of-work/${slug}/` },
  ]),
];
---

<PageLayout
  title={area.data.title}
  description={area.data.description}
  lang={lang}
  alternateUrls={{ sr: `/sr/oblasti-rada/${srSlug}/`, en: `/en/areas-of-work/${slug}/` }}
  schema={schemas}
>
  <article class="py-12 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="mb-8">
        <Breadcrumbs
          lang={lang}
          items={[
            { label: "Areas of Work", href: "/en/areas-of-work/" },
            { label: area.data.shortTitle },
          ]}
        />
      </div>

      <h1 class="font-heading text-h1 lg:text-display text-primary-900 mb-8">
        {area.data.title}
      </h1>

      {area.data.illustration ? (
        <div class="mb-10 flex justify-center">
          <Image
            src={area.data.illustration}
            alt={area.data.title}
            class="max-w-xs sm:max-w-sm w-full rounded-2xl shadow-md"
            width={400}
            loading="lazy"
          />
        </div>
      ) : (
        <div class="mb-10 rounded-2xl overflow-hidden bg-gradient-to-br from-primary-100 to-accent-100 h-48 lg:h-64 flex items-center justify-center">
          <svg class="w-20 h-20 text-primary-400/50" fill="currentColor" viewBox="0 0 24 24">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12" />
          </svg>
        </div>
      )}

      <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-primary-900 prose-p:text-text-secondary prose-p:leading-relaxed">
        <Content />
      </div>

      <!-- Q&A -->
      {area.data.qa && area.data.qa.length > 0 && (
        <div class="mt-12">
          <h2 class="font-heading text-h3 text-primary-900 mb-6">Questions & Answers</h2>
          <div class="space-y-8">
            {area.data.qa.map((item) => (
              <div class="border-l-4 border-primary-300 pl-6">
                <p class="font-heading font-semibold text-primary-900 mb-3">{item.question}</p>
                <p class="text-text-secondary leading-relaxed whitespace-pre-line">{item.answer}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- CTA -->
      <div class="mt-12 p-8 bg-gradient-to-br from-primary-50 to-accent-50 rounded-2xl text-center">
        <p class="font-heading text-h3 text-primary-900 mb-4">
          Contact us for a free consultation
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={`tel:${SITE.phoneRaw}`}
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white rounded-xl hover:bg-primary-700 transition-colors font-medium"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call us
          </a>
          <a
            href="/en/contact/"
            class="inline-flex items-center gap-2 px-6 py-3 border-2 border-primary-600 text-primary-600 rounded-xl hover:bg-primary-600 hover:text-white transition-colors font-medium"
          >
            Contact us
          </a>
        </div>
      </div>

      <!-- Related areas -->
      {relatedAreas.length > 0 && (
        <div class="mt-12">
          <h2 class="font-heading text-h3 text-primary-900 mb-6">
            Other areas we work on
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {relatedAreas.map((related) => {
              const relatedSlug = related.id.replace("en/", "").replace(".md", "");
              return (
                <a
                  href={`/en/areas-of-work/${relatedSlug}/`}
                  class="block p-4 rounded-xl border border-surface-400/30 bg-white hover:border-primary-300 hover:shadow-md transition-all text-center"
                >
                  <span class="font-heading text-primary-900 hover:text-primary-600">
                    {related.data.shortTitle}
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      )}
    </div>
  </article>
</PageLayout>
