---
import PageLayout from "@/layouts/PageLayout.astro";
import Breadcrumbs from "@/components/common/Breadcrumbs.astro";
import FAQSection from "@/components/home/FAQSection.astro";
import { SITE } from "@/lib/constants";
import { faqSchema, breadcrumbSchema } from "@/lib/schema";
import { useTranslations } from "@/i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const faqItems = Array.from({ length: 8 }, (_, i) => ({
  question: t(`faq.q${i + 1}`),
  answer: t(`faq.a${i + 1}`),
}));
---

<PageLayout
  title="Frequently Asked Questions"
  description="Frequently asked questions about psychotherapy: location, pricing, session length, online therapy, and everything you want to know."
  lang={lang}
  alternateUrls={{ sr: "/sr/faq/", en: "/en/faq/" }}
  schema={[
    faqSchema(faqItems),
    breadcrumbSchema([
      { name: "Home", url: `${SITE.url}/en/` },
      { name: "FAQ", url: `${SITE.url}/en/faq/` },
    ]),
  ]}
>
  <div class="py-6">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs lang={lang} items={[{ label: "FAQ" }]} />
    </div>
  </div>
  <FAQSection lang={lang} />
</PageLayout>
