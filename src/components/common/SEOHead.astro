---
import { SITE } from "@/lib/constants";
import type { Lang } from "@/i18n/utils";

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  alternateUrls?: { sr: string; en: string };
  noindex?: boolean;
}

const {
  title,
  description,
  lang,
  canonicalUrl,
  ogImage = "/images/og-image.jpg",
  ogType = "website",
  alternateUrls,
  noindex = false,
} = Astro.props;

const fullTitle = `${title} | ${SITE.name}`;
const canonical = canonicalUrl || Astro.url.href;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${SITE.url}${ogImage}`;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
<link rel="canonical" href={canonical} />

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:type" content={ogType} />
<meta property="og:locale" content={lang === "sr" ? "sr_RS" : "en_US"} />
<meta property="og:site_name" content={SITE.name} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Hreflang -->
{alternateUrls && (
  <>
    <link rel="alternate" hreflang="sr" href={`${SITE.url}${alternateUrls.sr}`} />
    <link rel="alternate" hreflang="en" href={`${SITE.url}${alternateUrls.en}`} />
    <link rel="alternate" hreflang="x-default" href={`${SITE.url}${alternateUrls.sr}`} />
  </>
)}
