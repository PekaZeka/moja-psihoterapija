---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  lang: Lang;
}

const { items, lang } = Astro.props;
const t = useTranslations(lang);
---

<nav aria-label="Breadcrumb" class="text-sm text-text-muted">
  <ol class="flex items-center flex-wrap gap-1">
    <li>
      <a href={`/${lang}/`} class="hover:text-primary-600 transition-colors">{t("nav.home")}</a>
    </li>
    {items.map((item) => (
      <li class="flex items-center gap-1">
        <svg class="w-4 h-4 text-text-muted/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        {item.href ? (
          <a href={item.href} class="hover:text-primary-600 transition-colors">{item.label}</a>
        ) : (
          <span class="text-text-primary font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
