  <!-- Phone -->
  <a
    href={`tel:${SITE.phoneRaw}`}
    class="flex items-center justify-center w-14 h-14 bg-primary-600 hover:bg-primary-700 text-white rounded-full shadow-lg hover:shadow-xl transition-all hover:scale-105 animate-pulse-slow"
    aria-label="Call us"
    data-event="phone_click"
  >
    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
  </a>
</div>

<script is:inline>
  document.querySelectorAll('[data-event]').forEach(function(el) {
    el.addEventListener('click', function() {
      if (window.dataLayer) {
        window.dataLayer.push({ event: el.getAttribute('data-event') });
      }
    });
  });
</script>

<style>
  @keyframes pulse-slow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(147, 51, 234, 0.4); }
    50% { box-shadow: 0 0 0 12px rgba(147, 51, 234, 0); }
  }
  .animate-pulse-slow {
    animation: pulse-slow 2.5s infinite;
  }
</style>
