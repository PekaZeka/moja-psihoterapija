---
import { useTranslations } from "@/i18n/utils";
import type { Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-16 lg:py-24 bg-surface-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-3xl sm:text-4xl text-primary-900 text-center mb-12">
      {t("modes.title")}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Online Card -->
      <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-lg transition-shadow duration-300 border border-surface-400/20">
        <div class="h-16 bg-primary-50 rounded-xl flex items-center justify-center mb-6 ">
          <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="font-heading text-2xl text-primary-900 mb-3">
          {t("modes.online")}
        </h3>
        <p class="text-text-secondary leading-relaxed">
          {t("modes.onlineDesc")}
        </p>
      </div>

      <!-- In Office Card -->
      <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-lg transition-shadow duration-300 border border-surface-400/20">
        <div class="h-16 bg-primary-50 rounded-xl flex items-center justify-center mb-6">
          <svg
            class="w-8 h-8 text-primary-600"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M20 9V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v2" />
            <path d="M2 11a2 2 0 0 1 4 0v2h12v-2a2 2 0 0 1 4 0v5a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2z" />
            <path d="M4 18v2" />
            <path d="M20 18v2" />
            <path d="M6 13v-2" />
            <path d="M18 13v-2" />
          </svg>
        </div>
      
        <h3 class="font-heading text-2xl text-primary-900 mb-3">
          {t("modes.office")}
        </h3>
      
        <p class="text-text-secondary leading-relaxed">
          {t("modes.officeDesc")}
        </p>
      </div>
    </div>
  </div>
</section>
