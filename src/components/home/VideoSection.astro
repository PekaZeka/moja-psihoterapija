---
import type { Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const title = lang === "sr" ? "Upoznajmo se" : "Let's get to know each other";
const therapistHref = lang === "sr" ? "/sr/vas-terapeut/" : "/en/your-therapist/";
const contactHref = lang === "sr" ? "/sr/kontakt/" : "/en/contact/";

const introText =
  lang === "sr"
    ? `Moje ime je Miroslav Jovanović i ja sam sistemski porodični psihoterapeut. Radim sa pojedincima, parovima i porodicama i imam dosta iskustva u radu sa osobama koje su prolazile kroz teške životne periode — od najtraumatičnijih događaja i različitih oblika zlostavljanja, do onih svakodnevnih izazova u partnerskim i porodičnim odnosima, na poslu, sa prijateljima ili sa samim sobom, naročito kada je u pitanju slika o sebi i vrednovanje sebe.

    Smatram da su moji najveći kvaliteti u radu empatičnost i prirodno neosuđujući pristup, ali to ćete vi sami najbolje proceniti kada se budemo upoznali.

    Nisam jedan od onih terapeuta koji samo slušaju, klimaju glavom i pitaju: "Kako se osećate povodom toga?". Trudim se da aktivno učestvujem u seansi i da što više pružim svojim klijentima. Nastojim da vas podstaknem da napravite iskorak i promenu koju želite, ali sve to tempom koji vama odgovara.
`
: `My name is Miroslav Jovanović, and I am a systemic family therapist. I work with individuals, couples, and families, and I have extensive experience supporting people who have gone through difficult periods in life — from the most traumatic events and various forms of abuse to everyday challenges in romantic and family relationships, at work, with friends, or within themselves, especially when it comes to self-image and self-worth.

I believe that my greatest strengths in therapy are empathy and a naturally non-judgmental approach, but you will be the best judge of that when we meet.

I am not one of those therapists who simply listen, nod, and ask, "How do you feel about that?". I strive to take an active role in each session and to offer my clients as much as I can. My goal is to encourage you to take the step forward and make the change you want, always at a pace that feels right for you.`;
---

<section class="py-16 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-h2 lg:text-h1 text-primary-900 text-center mb-10">
      {title}
    </h2>

    <!-- Video -->
    <div class="relative rounded-2xl overflow-hidden shadow-xl aspect-video bg-primary-950 mb-10">
      <iframe
        src="https://www.youtube.com/embed/iZ8epE8PTco"
        title={title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        class="absolute inset-0 w-full h-full"
        loading="lazy"
      ></iframe>
    </div>

    <!-- Text card -->
    <div class="rounded-2xl bg-surface-50 border border-surface-200 shadow-sm p-6 sm:p-8">
      <div class="space-y-5 text-base sm:text-lg leading-8 text-text-secondary whitespace-pre-line">
        {introText}
      </div>

      <div class="mt-8 flex flex-col sm:flex-row gap-4">
        <a
          href={therapistHref}
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary-600 text-white font-medium rounded-xl shadow-md hover:bg-primary-700 transition-all"
        >
          {lang === "sr" ? "Više o meni" : "More about me"}
        </a>
        <a
          href={contactHref}
          class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-primary-200 text-primary-700 font-medium rounded-xl hover:bg-primary-50 transition-all"
        >
          {lang === "sr" ? "Kontakt" : "Contact"}
        </a>
      </div>
    </div>
  </div>
</section>
